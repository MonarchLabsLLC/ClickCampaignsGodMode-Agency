# ClickCampaigns God Mode — Optional API Keys
#
# These are optional. Core functionality (copy, funnels, emails, ads) works without them.
# Copy this file to .env and fill in the keys you want to use.
#
#   cp .env.example .env
#

# Google Gemini — AI-generated images for marketing assets
# Get your free key at https://ai.google.dev/
GEMINI_API_KEY=

# Pexels — Free stock photos for landing pages, PDFs, and presentations
# Get your free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Firecrawl — Clone any webpage as a starting point for funnel pages
# Get your key at https://www.firecrawl.dev/
FIRECRAWL_API_KEY=
